generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum NovedadType {
  HORA_EXTRA
  INCAPACIDAD
}

enum VacationStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
}

// ─── Modelos ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(USER)
  hireDate     DateTime // Clave para cálculo de vacaciones (15 días/año)
  createdAt    DateTime @default(now())

  novedades  Novedad[]
  vacaciones Vacation[]
}

model Novedad {
  id        String      @id @default(uuid())
  type      NovedadType
  startDate DateTime
  endDate   DateTime? // Fecha fin para incapacidades
  hours     Int? // Cantidad de horas para HORA_EXTRA
  reason    String
  createdAt DateTime    @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Vacation {
  id            String         @id @default(uuid())
  startDate     DateTime
  endDate       DateTime
  requestedDays Int
  status        VacationStatus @default(PENDIENTE)
  createdAt     DateTime       @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

